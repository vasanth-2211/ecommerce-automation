<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Ecommerce Automation Suite">
    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>
    <test name="Login Tests">
        <classes>
            <class name="tests.ValidLoginTest"/>
            <class name="tests.InvalidLoginTest"/>
            <class name="tests.AddProductToCartTest"/>
            <class name="tests.RemoveFromCartTest"/>
            <class name="tests.CheckoutNavigationTest"/>
            <class name="tests.AddMultipleProductsTest"/>
            <class name="tests.CheckoutFlowTest"/>
        </classes>
    </test>
</suite>
