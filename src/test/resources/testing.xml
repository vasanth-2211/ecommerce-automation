<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Ecommerce Automation Suite" parallel="classes" thread-count="3">

    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="Regression Tests">

        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>

        <classes>
            <class name="tests.ValidLoginTest"/>
            <class name="tests.InvalidLoginTest"/>
            <class name="tests.AddProductToCartTest"/>
            <class name="tests.RemoveFromCartTest"/>
            <class name="tests.AddMultipleProductsTest"/>
            <class name="tests.CheckoutNavigationTest"/>
            <class name="tests.CheckoutFlowTest"/>
        </classes>

    </test>

</suite>
