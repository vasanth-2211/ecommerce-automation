<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Safari Suite" parallel="false" thread-count="1">

    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="Safari Regression Tests">
        <parameter name="browser" value="safari"/>

        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>

        <packages>
            <package name="tests"/>
        </packages>

    </test>

</suite>
